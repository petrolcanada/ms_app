# API Configuration (optional)
# Only set this if you need to point at a remote API server.
# In dev, the CRA proxy in package.json forwards /api/* to localhost:5000.
# In prod, Express serves the frontend and API on the same port.
# REACT_APP_API_BASE_URL=https://my-remote-api.example.com

# Tunneling (localtunnel, ngrok, etc.)
# Uncomment the line below to allow non-localhost hosts in the CRA dev server.
# Required when exposing the app via a tunneling tool.
# DANGEROUSLY_DISABLE_HOST_CHECK=true

# Add other environment variables here as needed
